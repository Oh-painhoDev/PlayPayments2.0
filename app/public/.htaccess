<IfModule mod_php.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 20M
    php_value memory_limit 256M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Cache Control - Imagens, CSS e JS carregam instantaneamente
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imagens - 1 ano de cache
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS e JavaScript - 1 ano de cache
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    
    # Fontes - 1 ano de cache
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    
    # HTML sem cache
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Cache-Control headers para assets estáticos
<IfModule mod_headers.c>
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(woff2|woff|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Security Headers
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ============================================
    # PRIORIDADE MÁXIMA: Rotas de fotos de usuários
    # Estas rotas DEVEM ser processadas pelo Laravel
    # ANTES de qualquer outra verificação
    # IMPORTANTE: Mesmo que o arquivo exista fisicamente,
    # sempre processar pelo Laravel para controle de acesso
    # ============================================
    # Forçar processamento pelo Laravel mesmo se arquivo existir
    # Usar ^ antes do $ para garantir que capture tudo
    RewriteCond %{REQUEST_URI} ^/users/photos/ [NC]
    RewriteRule ^.*$ index.php [L,QSA]
    
    RewriteCond %{REQUEST_URI} ^/storage/users/photos/ [NC]
    RewriteRule ^.*$ index.php [L,QSA]
    
    RewriteCond %{REQUEST_URI} ^/api/storage/users/photos/ [NC]
    RewriteRule ^.*$ index.php [L,QSA]

    # 🔒 PROTEÇÃO CRÍTICA - BLOQUEAR ACESSO A ARQUIVOS SENSÍVEIS
    # Bloquear acesso direto a arquivos .env (qualquer variação)
    RewriteRule ^\.env - [F,L]
    RewriteRule ^\.env\. - [F,L]
    RewriteRule ^\.env\.local - [F,L]
    RewriteRule ^\.env\.production - [F,L]
    RewriteRule ^\.env\.staging - [F,L]
    RewriteRule ^\.env\.development - [F,L]
    
    # Bloquear acesso a outros arquivos sensíveis
    RewriteRule ^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|artisan)$ - [F,L]
    
    # Bloquear acesso a diretórios sensíveis através da URL
    # EXCETO para /storage/users/photos/ que já foi tratado acima
    RewriteCond %{REQUEST_URI} !^/storage/users/photos/ [NC]
    RewriteCond %{REQUEST_URI} !^/api/storage/users/photos/ [NC]
    RewriteCond %{REQUEST_URI} ^/(\.env|\.env\.|composer\.|package|yarn\.lock|artisan|bootstrap|config|database|routes|storage|vendor) [NC]
    RewriteRule ^ - [F,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]
    
    # Para outros arquivos estáticos, verificar se existe
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# 🔒 PROTEÇÃO ADICIONAL - BLOQUEAR ARQUIVOS SENSÍVEIS
<FilesMatch "^(\.env|\.env\.|\.env\.local|\.env\.production|\.env\.staging|\.env\.development|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|artisan)$">
    Require all denied
</FilesMatch>

# Bloquear acesso a arquivos .env de qualquer forma
<Files ".env*">
    Require all denied
</Files>

# Bloquear listagem de diretórios
Options -Indexes
